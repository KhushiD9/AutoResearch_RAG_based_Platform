# ─────────────────────────────────────────────
#  Research Paper Assistant — Environment File
# ─────────────────────────────────────────────
#  Copy this file to .env and fill in your key.
#  Only ANTHROPIC_API_KEY is required to run.
# ─────────────────────────────────────────────

GEMINI_API_KEY=your_gemini_api_key_here

# Optional — leave blank to skip PostgreSQL (history uses in-memory by default)
DATABASE_URL=

# Auth (not required unless you enable auth middleware)
SECRET_KEY=change_this_in_production
